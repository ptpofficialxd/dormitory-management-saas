{
  "name": "dorm-saas",
  "version": "0.0.1",
  "private": true,
  "description": "Dormitory / Apartment Management SaaS (Thailand) — LINE OA + Admin Web + Backend API",
  "packageManager": "bun@1.1.38",
  "engines": {
    "bun": ">=1.1.30",
    "node": ">=20.11.0"
  },
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "web": "bun run --cwd apps/web-admin dev",
    "api": "bun run --cwd apps/api dev",
    "api:test": "bun run --cwd apps/api test",
    "liff": "bun run --cwd apps/liff-tenant dev",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch --parallel",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "infra:start": "docker compose up -d",
    "infra:stop": "docker compose down",
    "infra:reset": "docker compose down -v && docker compose up -d",
    "db:generate": "bun run --filter @dorm/db generate",
    "db:migrate:init": "bun run --filter @dorm/db migrate:init",
    "db:migrate": "bun run --filter @dorm/db migrate:dev",
    "db:migrate:reset": "bun run --filter @dorm/db migrate:reset",
    "db:studio": "bun run --filter @dorm/db studio",
    "db:apply-rls": "bun run --filter @dorm/db apply-rls",
    "db:apply-rls:test": "bun run --filter @dorm/db apply-rls:test",
    "db:apply-roles": "bun run --filter @dorm/db apply-roles",
    "db:apply-roles:test": "bun run --filter @dorm/db apply-roles:test",
    "db:seed": "bun run --filter @dorm/db seed",
    "db:seed:test": "bun run --filter @dorm/db seed:test",
    "db:setup:test": "bun run --filter @dorm/db db:setup:test",
    "db:reset:test": "bun run --filter @dorm/db db:reset:test",
    "db:reset": "bun run --filter @dorm/db db:reset",
    "db:setup": "bun run --filter @dorm/db db:setup",
    "db:test": "bun run --filter @dorm/db test",
    "shared:test": "bun run --filter @dorm/shared test",
    "shared:typecheck": "bun run --filter @dorm/shared typecheck",
    "check:bun-api": "node ./scripts/check-no-bun-api.mjs",
    "check:roles": "node ./scripts/check-no-hardcoded-roles.mjs",
    "check:audit-immutable": "node ./scripts/check-no-audit-mutation.mjs",
    "e2e:invite": "node ./scripts/e2e-create-invite.mjs",
    "verify": "bun run lint && bun run check:bun-api && bun run check:roles && bun run check:audit-immutable && bun run typecheck && bun run build && bun run shared:test && bun run --cwd apps/api test",
    "verify:full": "bun run verify && bun run db:reset:test && bun run db:test && bun run --cwd apps/api test:e2e",
    "prepare": "echo 'skip husky for now'"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/bun": "1.1.14",
    "turbo": "2.9.6",
    "typescript": "5.6.3"
  },
  "trustedDependencies": [
    "@biomejs/biome",
    "esbuild",
    "prisma",
    "@prisma/client",
    "@prisma/engines"
  ]
}
