{
  "name": "@dorm/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Dorm SaaS backend — NestJS + Fastify. JWT admin auth, RLS tenant isolation, AuditLog interceptor.",
  "main": "./src/main.ts",
  "scripts": {
    "dev": "dotenv -e ../../.env -- tsx watch src/main.ts",
    "start": "dotenv -e ../../.env -- tsx src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "dotenv -e ../../.env.test -- vitest --run",
    "test:watch": "dotenv -e ../../.env.test -- vitest",
    "test:e2e": "dotenv -e ../../.env.test -- vitest --run --config vitest.e2e.config.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "3.705.0",
    "@aws-sdk/s3-request-presigner": "3.705.0",
    "@dorm/db": "workspace:*",
    "@dorm/shared": "workspace:*",
    "@fastify/cookie": "9.4.0",
    "@fastify/helmet": "12.0.1",
    "@nestjs/common": "10.4.15",
    "@nestjs/core": "10.4.15",
    "@nestjs/platform-fastify": "10.4.15",
    "fastify": "4.28.1",
    "jose": "5.9.6",
    "qrcode": "1.5.4",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@swc/core": "1.10.1",
    "@types/node": "20.17.10",
    "@types/qrcode": "1.5.5",
    "@types/supertest": "6.0.2",
    "dotenv-cli": "7.4.4",
    "supertest": "7.0.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3",
    "unplugin-swc": "1.5.1",
    "vitest": "2.1.8"
  }
}
