{
  "name": "@dorm/web-admin",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Dorm SaaS admin web — Next.js 15 App Router. JWT auth, path-based /c/[slug]/ routing, RBAC.",
  "scripts": {
    "dev": "dotenv -e ../../.env -- next dev -p 3001",
    "build": "next build",
    "start": "dotenv -e ../../.env -- next start -p 3001",
    "clean": "rm -rf .next .turbo tsconfig.tsbuildinfo node_modules/.cache",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@dorm/shared": "workspace:*",
    "@hookform/resolvers": "3.9.1",
    "@radix-ui/react-label": "2.1.1",
    "@radix-ui/react-slot": "1.1.1",
    "@tanstack/react-query": "5.59.20",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "jose": "5.9.6",
    "lucide-react": "0.469.0",
    "next": "15.1.3",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-hook-form": "7.54.2",
    "tailwind-merge": "2.5.5",
    "tailwindcss-animate": "1.0.7",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@tanstack/react-query-devtools": "5.59.20",
    "@types/node": "20.17.10",
    "@types/react": "18.3.12",
    "@types/react-dom": "18.3.1",
    "autoprefixer": "10.4.20",
    "dotenv-cli": "7.4.4",
    "postcss": "8.4.49",
    "tailwindcss": "3.4.15",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
