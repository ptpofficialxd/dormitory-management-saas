{
  "name": "@dorm/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Shared primitives: Zod schemas, RBAC, money (Decimal), date, PromptPay — used by api/web/liff",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./constants": {
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.js",
      "default": "./dist/constants.js"
    },
    "./money": {
      "types": "./dist/money.d.ts",
      "import": "./dist/money.js",
      "default": "./dist/money.js"
    },
    "./date": {
      "types": "./dist/date.d.ts",
      "import": "./dist/date.js",
      "default": "./dist/date.js"
    },
    "./rbac": {
      "types": "./dist/rbac/index.d.ts",
      "import": "./dist/rbac/index.js",
      "default": "./dist/rbac/index.js"
    },
    "./promptpay": {
      "types": "./dist/promptpay.d.ts",
      "import": "./dist/promptpay.js",
      "default": "./dist/promptpay.js"
    },
    "./slug": {
      "types": "./dist/slug.d.ts",
      "import": "./dist/slug.js",
      "default": "./dist/slug.js"
    },
    "./errors": {
      "types": "./dist/errors.d.ts",
      "import": "./dist/errors.js",
      "default": "./dist/errors.js"
    },
    "./zod": {
      "types": "./dist/zod/index.d.ts",
      "import": "./dist/zod/index.js",
      "default": "./dist/zod/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist .turbo tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "node ../../scripts/vitest.mjs --run",
    "test:watch": "node ../../scripts/vitest.mjs"
  },
  "dependencies": {
    "date-fns": "4.1.0",
    "date-fns-tz": "3.2.0",
    "decimal.js": "10.4.3",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.17.10",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  }
}
