{
  "name": "@dorm/db",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Prisma schema + RLS-enforced client + seed for Dorm SaaS",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "generate": "dotenv -e ../../.env -- prisma generate",
    "migrate:init": "dotenv -e ../../.env -- prisma migrate dev --name init",
    "migrate:init:test": "dotenv -e ../../.env.test -- prisma migrate dev --name init --skip-seed",
    "migrate:dev": "dotenv -e ../../.env -- prisma migrate dev",
    "migrate:deploy": "dotenv -e ../../.env -- prisma migrate deploy",
    "migrate:deploy:test": "dotenv -e ../../.env.test -- prisma migrate deploy",
    "migrate:reset": "dotenv -e ../../.env -- prisma migrate reset --force --skip-seed",
    "migrate:reset:test": "dotenv -e ../../.env.test -- prisma migrate reset --force --skip-seed",
    "studio": "dotenv -e ../../.env -- prisma studio",
    "apply-rls": "dotenv -e ../../.env -- bun run src/apply-rls.ts",
    "apply-rls:test": "dotenv -e ../../.env.test -- bun run src/apply-rls.ts",
    "apply-roles": "dotenv -e ../../.env -- bun run src/apply-roles.ts",
    "apply-roles:test": "dotenv -e ../../.env.test -- bun run src/apply-roles.ts",
    "seed": "dotenv -e ../../.env -- bun run src/seed.ts",
    "seed:test": "dotenv -e ../../.env.test -- bun run src/seed.ts",
    "db:setup": "bun run migrate:init && bun run apply-rls && bun run apply-roles && bun run seed",
    "db:setup:test": "bun run apply-rls:test && bun run apply-roles:test && bun run seed:test",
    "db:reset": "bun run migrate:reset && bun run apply-rls && bun run apply-roles && bun run seed",
    "db:reset:test": "bun run migrate:reset:test && bun run apply-rls:test && bun run apply-roles:test && bun run seed:test",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist .turbo tsconfig.tsbuildinfo",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "test": "dotenv -e ../../.env.test -- node ../../scripts/vitest.mjs --run",
    "test:watch": "dotenv -e ../../.env.test -- node ../../scripts/vitest.mjs"
  },
  "dependencies": {
    "@node-rs/argon2": "2.0.2",
    "@prisma/client": "6.1.0"
  },
  "devDependencies": {
    "@types/node": "20.17.10",
    "dotenv-cli": "7.4.4",
    "prisma": "6.1.0",
    "typescript": "5.6.3",
    "vitest": "2.1.8"
  },
  "prisma": {
    "seed": "bun run src/seed.ts"
  }
}
