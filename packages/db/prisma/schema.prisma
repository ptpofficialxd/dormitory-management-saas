// Dorm SaaS — Prisma schema (source of truth).
// See CLAUDE.md §3 for non-negotiable rules.
// See docs/adr/0002 for RLS strategy, 0005 for Decimal money.

generator client {
  provider        = "prisma-client-js"
  engineType      = "library"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
  extensions = [pgcrypto]
}

// =========================================================================
// Enums
// =========================================================================

enum CompanyStatus {
  active
  suspended
  churned

  @@map("company_status")
}

enum UserStatus {
  active
  disabled

  @@map("user_status")
}

enum Role {
  company_owner
  property_manager
  staff
  tenant
  guardian

  @@map("role")
}

enum UnitStatus {
  vacant
  occupied
  maintenance
  reserved

  @@map("unit_status")
}

enum TenantStatus {
  active
  moved_out
  blocked

  @@map("tenant_status")
}

enum ContractStatus {
  draft
  active
  ended
  terminated

  @@map("contract_status")
}

enum MeterKind {
  water
  electric

  @@map("meter_kind")
}

enum InvoiceStatus {
  draft
  issued
  partially_paid
  paid
  void
  overdue

  @@map("invoice_status")
}

enum InvoiceItemKind {
  rent
  water
  electric
  common_fee
  late_fee
  deposit
  other

  @@map("invoice_item_kind")
}

enum PaymentMethod {
  promptpay
  cash
  bank_transfer

  @@map("payment_method")
}

enum PaymentStatus {
  pending
  confirmed
  rejected

  @@map("payment_status")
}

// `pending`   — code generated, not yet redeemed
// `redeemed`  — successfully bound to a LINE user (terminal, single-use)
// `expired`   — TTL elapsed without redemption (terminal)
// `revoked`   — admin revoked manually (terminal; e.g. tenant lost the code)
//
// Why an explicit `expired` state instead of computing from `expiresAt`:
// the redeem endpoint needs O(1) atomic CAS on `status = 'pending'`, and a
// background sweep (or first-touch transition) flips stale `pending` rows to
// `expired` for clean audit trails + admin UI listing.
enum TenantInviteStatus {
  pending
  redeemed
  expired
  revoked

  @@map("tenant_invite_status")
}

// =========================================================================
// Maintenance enums (Sprint B / Task #87) — mirror @dorm/shared/zod/maintenance.ts
//
// Status state machine (enforced by service):
//   open → in_progress → resolved → closed
//                          ↓
//                      cancelled (terminal from any non-resolved state)
// `cancelled` is its own terminal — distinct from `closed` so audit trails
// can tell "we fixed it" apart from "we won't fix it" (admin discretion).
//
// Priority drives admin sort order + future SLA. `normal` is the default at
// the Zod input boundary (tenants don't pick a priority — admin triages).
//
// Category drives icon + future routing. Keep this small; adding a value is
// a Prisma enum migration + Zod enum widen + admin UI label update.
// =========================================================================

enum MaintenanceStatus {
  open
  in_progress
  resolved
  closed
  cancelled

  @@map("maintenance_status")
}

enum MaintenancePriority {
  low
  normal
  high
  urgent

  @@map("maintenance_priority")
}

enum MaintenanceCategory {
  plumbing
  electrical
  aircon
  appliance
  furniture
  structural
  internet
  other

  @@map("maintenance_category")
}

// =========================================================================
// Company — tenant root (every other tenant-owned row references this id)
// =========================================================================

model Company {
  id        String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug      String        @unique @db.VarChar(32)
  name      String        @db.VarChar(128)
  status    CompanyStatus @default(active)
  // PromptPay owner ID for issuing invoices. Accepts:
  //   - 10-digit phone (e.g. `0812345678`),
  //   - 13-digit national ID / tax ID,
  //   - 15-digit e-wallet ID.
  // Nullable so a company can be seeded before PromptPay is configured;
  // the invoice-issue flow MUST check non-null before generating a QR.
  // Type is inferred from digit-length at the shared/promptpay boundary
  // — no separate `promptPayType` column needed.
  promptPayId   String?       @map("prompt_pay_id") @db.VarChar(16)
  // Merchant name shown in the bank app during scan (EMVCo tag 59).
  // PromptPay spec caps at 25 ASCII chars; we keep 64 to absorb escaping
  // headroom and truncate/sanitize at the QR-generation boundary.
  promptPayName String?       @map("prompt_pay_name") @db.VarChar(64)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  users           User[]
  roleAssignments RoleAssignment[]
  properties      Property[]
  units           Unit[]
  auditLogs       AuditLog[]
  tenants         Tenant[]
  contracts       Contract[]
  meters          Meter[]
  readings        Reading[]
  invoices        Invoice[]
  invoiceItems    InvoiceItem[]
  payments        Payment[]
  slips           Slip[]
  // 1 company = 1 LINE Official Account in MVP. Use `?` so a company can
  // exist before LINE is configured (typical onboarding flow). Multi-OA
  // support is a future migration: drop the `@unique` on companyId, add
  // a name/role per row, expose channel selector in admin UI.
  lineChannel     CompanyLineChannel?
  webhookEvents   WebhookEvent[]
  tenantInvites   TenantInvite[]
  maintenanceRequests MaintenanceRequest[]

  @@index([status])
  @@map("company")
}

// =========================================================================
// User — admin/staff user (email/password login). Tenant users live in a
// separate `tenant` table added in Step 3 (LIFF / LINE Login path).
// =========================================================================

model User {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String     @map("company_id") @db.Uuid
  email        String     @db.VarChar(255)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  displayName  String     @map("display_name") @db.VarChar(128)
  status       UserStatus @default(active)
  lastLoginAt  DateTime?  @map("last_login_at") @db.Timestamptz(6)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  company             Company          @relation(fields: [companyId], references: [id], onDelete: Restrict)
  roleAssignments     RoleAssignment[]
  auditLogs           AuditLog[]       @relation("AuditLogActor")
  readingsTakenBy     Reading[]        @relation("ReadingTakenBy")
  paymentsConfirmed   Payment[]        @relation("PaymentConfirmer")
  tenantInvitesIssued TenantInvite[]   @relation("TenantInviteIssuer")
  // Sprint B (Task #87): maintenance tickets the staff/manager has been
  // assigned to. SetNull on user delete so the ticket history survives —
  // operator's "who did this work" admin view falls back to "unassigned"
  // if the user record is later removed (audit log keeps the snapshot).
  maintenanceAssigned MaintenanceRequest[] @relation("MaintenanceAssignee")

  // Email uniqueness scoped to company — same email may register at multiple dorms.
  @@unique([companyId, email])
  @@index([companyId])
  @@map("user")
}

// =========================================================================
// RoleAssignment — RBAC table-driven (CLAUDE.md §3.13).
// A user may hold multiple roles within the same company.
// =========================================================================

model RoleAssignment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      Role
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId, role])
  @@index([companyId])
  @@index([userId])
  @@map("role_assignment")
}

// =========================================================================
// Property — a building/site owned by a company
// =========================================================================

model Property {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  slug      String   @db.VarChar(64)
  name      String   @db.VarChar(128)
  address   String?  @db.VarChar(512)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  units   Unit[]

  @@unique([companyId, slug])
  @@index([companyId])
  @@map("property")
}

// =========================================================================
// Unit — a rentable room. Floor/UnitType normalization deferred to Step 3.
// =========================================================================

model Unit {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId  String     @map("company_id") @db.Uuid
  propertyId String     @map("property_id") @db.Uuid
  unitNumber String     @map("unit_number") @db.VarChar(32)
  floor      Int        @default(1)
  status     UnitStatus @default(vacant)
  baseRent   Decimal    @map("base_rent") @db.Decimal(10, 2)
  sizeSqm    Decimal?   @map("size_sqm") @db.Decimal(6, 2)
  notes      String?    @db.VarChar(512)
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  company   Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  property  Property   @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  contracts Contract[]
  meters    Meter[]
  invoices  Invoice[]
  maintenanceRequests MaintenanceRequest[]

  @@unique([propertyId, unitNumber])
  @@index([companyId])
  @@index([propertyId])
  @@index([status])
  @@map("unit")
}

// =========================================================================
// AuditLog — append-only (enforced by DB trigger in rls-policies.sql).
// Required on every mutation touching PII or money (CLAUDE.md §3.7).
// =========================================================================

model AuditLog {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  actorUserId String?  @map("actor_user_id") @db.Uuid
  action      String   @db.VarChar(64)
  resource    String   @db.VarChar(64)
  resourceId  String?  @map("resource_id") @db.VarChar(64)
  metadata    Json     @default("{}")
  ipAddress   String?  @map("ip_address") @db.Inet
  userAgent   String?  @map("user_agent") @db.VarChar(512)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  actor   User?   @relation("AuditLogActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt(sort: Desc)])
  @@index([resource, resourceId])
  @@map("audit_log")
}

// =========================================================================
// Tenant — LINE LIFF user. Separate from `user` (admin/staff path) because
// authentication + identity model differs (LINE Login vs email/password).
// PII fields (nationalId, phone) stored encrypted at-rest via pgcrypto —
// encryption happens in the service layer before INSERT (CLAUDE.md §3.8).
// =========================================================================

model Tenant {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String       @map("company_id") @db.Uuid
  // Nullable since #41: admin can create a Tenant before the human even
  // touches the LIFF app. The `lineUserId` is set later when the tenant
  // redeems an invite-code (TenantInvite). The `(companyId, lineUserId)`
  // unique index keeps duplicate-prevention semantics — Postgres treats
  // multiple NULLs as DISTINCT, so unbound tenants don't collide with
  // each other while still blocking two tenants binding the same
  // LINE userId within one company.
  lineUserId  String?      @map("line_user_id") @db.VarChar(64)
  displayName String       @map("display_name") @db.VarChar(128)
  pictureUrl  String?      @map("picture_url") @db.VarChar(512)
  // Encrypted at rest (pgcrypto). Stored as VARCHAR of base64-encoded ciphertext.
  nationalId  String?      @map("national_id") @db.VarChar(512)
  phone       String?      @db.VarChar(512)
  status      TenantStatus @default(active)
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6)

  company   Company        @relation(fields: [companyId], references: [id], onDelete: Restrict)
  contracts Contract[]
  invoices  Invoice[]
  payments  Payment[]
  invites   TenantInvite[]
  maintenanceRequests MaintenanceRequest[]

  // One tenant record per (company, LINE userId). Same LINE user may be a
  // tenant at multiple dorms — each gets a separate row.
  @@unique([companyId, lineUserId])
  @@index([companyId])
  @@index([status])
  @@map("tenant")
}

// =========================================================================
// Contract — rental contract. Rent/deposit snapshot at signing time; if the
// owner raises the unit's base rent, existing contracts stay at the old rate
// until renewed.
// =========================================================================

model Contract {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId     String         @map("company_id") @db.Uuid
  unitId        String         @map("unit_id") @db.Uuid
  tenantId      String         @map("tenant_id") @db.Uuid
  // ISO date (no time component). Contracts start/end at midnight Asia/Bangkok.
  startDate     DateTime       @map("start_date") @db.Date
  // NULL = open-ended monthly contract. Most Thai dorm contracts are month-to-month.
  endDate       DateTime?      @map("end_date") @db.Date
  rentAmount    Decimal        @map("rent_amount") @db.Decimal(10, 2)
  depositAmount Decimal        @map("deposit_amount") @db.Decimal(10, 2)
  status        ContractStatus @default(draft)
  notes         String?        @db.VarChar(1024)
  createdAt     DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  unit     Unit      @relation(fields: [unitId], references: [id], onDelete: Restrict)
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  invoices Invoice[]

  @@index([companyId])
  @@index([unitId, status])
  @@index([tenantId, status])
  @@index([status, startDate])
  @@map("contract")
}

// =========================================================================
// Meter — one water + one electric meter per unit (enforced by unique index).
// `ratePerUnit` uses Decimal(10,4) because Thai electric tariffs are quoted
// to 4 decimals (e.g. 5.8124 THB/kWh under PEA's progressive tariff).
// =========================================================================

model Meter {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId     String    @map("company_id") @db.Uuid
  unitId        String    @map("unit_id") @db.Uuid
  kind          MeterKind
  serialNo      String?   @map("serial_no") @db.VarChar(64)
  unitOfMeasure String    @map("unit_of_measure") @db.VarChar(16)
  ratePerUnit   Decimal   @map("rate_per_unit") @db.Decimal(10, 4)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  company  Company   @relation(fields: [companyId], references: [id], onDelete: Restrict)
  unit     Unit      @relation(fields: [unitId], references: [id], onDelete: Cascade)
  readings Reading[]

  @@unique([unitId, kind])
  @@index([companyId])
  @@map("meter")
}

// =========================================================================
// Reading — monthly meter reading. `consumption` is derived (current minus
// previous) but stored for audit — recomputing from history would drift if
// a past reading gets corrected.
// =========================================================================

model Reading {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId     String   @map("company_id") @db.Uuid
  meterId       String   @map("meter_id") @db.Uuid
  period        String   @db.VarChar(7)
  valueCurrent  Decimal  @map("value_current") @db.Decimal(12, 2)
  valuePrevious Decimal  @map("value_previous") @db.Decimal(12, 2)
  consumption   Decimal  @db.Decimal(12, 2)
  // R2 object key (private bucket). Signed URL generated on read.
  photoKey      String?  @map("photo_key") @db.VarChar(512)
  readAt        DateTime @map("read_at") @db.Timestamptz(6)
  readByUserId  String?  @map("read_by_user_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  company      Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  meter        Meter         @relation(fields: [meterId], references: [id], onDelete: Cascade)
  readBy       User?         @relation("ReadingTakenBy", fields: [readByUserId], references: [id], onDelete: SetNull)
  invoiceItems InvoiceItem[]

  // One reading per meter per billing period.
  @@unique([meterId, period])
  @@index([companyId])
  @@index([period])
  @@map("reading")
}

// =========================================================================
// Invoice — monthly bill for a contract. Totals computed by the service
// using `money.add` (never JS +). One invoice per contract per period.
// =========================================================================

model Invoice {
  id           String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId    String        @map("company_id") @db.Uuid
  contractId   String        @map("contract_id") @db.Uuid
  unitId       String        @map("unit_id") @db.Uuid
  tenantId     String        @map("tenant_id") @db.Uuid
  period       String        @db.VarChar(7)
  issueDate    DateTime      @map("issue_date") @db.Timestamptz(6)
  dueDate      DateTime      @map("due_date") @db.Timestamptz(6)
  subtotal     Decimal       @db.Decimal(10, 2)
  total        Decimal       @db.Decimal(10, 2)
  status       InvoiceStatus @default(draft)
  // PromptPay QR payload (string; generated by packages/shared/promptpay).
  // Stored so we don't regenerate on every fetch + the QR stays stable even
  // if the tenant's PromptPay ID changes mid-period.
  promptPayRef String?       @map("promptpay_ref") @db.VarChar(512)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  company  Company       @relation(fields: [companyId], references: [id], onDelete: Restrict)
  contract Contract      @relation(fields: [contractId], references: [id], onDelete: Restrict)
  unit     Unit          @relation(fields: [unitId], references: [id], onDelete: Restrict)
  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  items    InvoiceItem[]
  payments Payment[]

  // Uniqueness on (contractId, period) is enforced by a PARTIAL UNIQUE
  // INDEX `WHERE status != 'void'` — defined in the migration SQL because
  // Prisma 6 still doesn't support partial indexes in the schema DSL.
  // Why partial: voiding an invoice (admin mistake / contract change)
  // shouldn't burn the (contract, period) slot — admin must be able to
  // regenerate. Without the partial filter, the void row blocks reuse
  // forever and the only escape is hand-deletion (which destroys the
  // audit trail).
  // The regular composite index below covers general lookups; the
  // partial unique index sits alongside for constraint enforcement.
  @@index([contractId, period])
  @@index([companyId])
  @@index([tenantId, status])
  @@index([status, dueDate])
  @@map("invoice")
}

// =========================================================================
// InvoiceItem — a single line on an invoice. `lineTotal = quantity * unitPrice`
// computed by service layer using `money.mul` (ADR-0005, never JS *).
// When `kind = water|electric`, `readingId` links back to the meter reading
// so we can audit / recompute.
// =========================================================================

model InvoiceItem {
  id          String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String          @map("company_id") @db.Uuid
  invoiceId   String          @map("invoice_id") @db.Uuid
  kind        InvoiceItemKind
  description String          @db.VarChar(255)
  quantity    Decimal         @db.Decimal(12, 2)
  // 4 decimals: rates like 5.8124 THB/kWh shouldn't round at the line-item level.
  unitPrice   Decimal         @map("unit_price") @db.Decimal(10, 4)
  lineTotal   Decimal         @map("line_total") @db.Decimal(10, 2)
  readingId   String?         @map("reading_id") @db.Uuid
  sortOrder   Int             @default(0) @map("sort_order")
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)

  company Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  invoice Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  reading Reading? @relation(fields: [readingId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([invoiceId, sortOrder])
  @@map("invoice_item")
}

// =========================================================================
// Payment — a single payment attempt against an invoice. An invoice may
// have multiple payments (partial payments). `idempotencyKey` is scoped
// per-company so two tenants can reuse the same client-chosen key.
// =========================================================================

model Payment {
  id                String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId         String        @map("company_id") @db.Uuid
  invoiceId         String        @map("invoice_id") @db.Uuid
  tenantId          String        @map("tenant_id") @db.Uuid
  amount            Decimal       @db.Decimal(10, 2)
  method            PaymentMethod @default(promptpay)
  status            PaymentStatus @default(pending)
  paidAt            DateTime?     @map("paid_at") @db.Timestamptz(6)
  confirmedAt       DateTime?     @map("confirmed_at") @db.Timestamptz(6)
  confirmedByUserId String?       @map("confirmed_by_user_id") @db.Uuid
  rejectionReason   String?       @map("rejection_reason") @db.VarChar(512)
  // Idempotency-Key header per CLAUDE.md §3.10 — client-chosen ULID/UUID.
  idempotencyKey    String        @map("idempotency_key") @db.VarChar(128)
  createdAt         DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)

  company     Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Restrict)
  tenant      Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  confirmedBy User?   @relation("PaymentConfirmer", fields: [confirmedByUserId], references: [id], onDelete: SetNull)
  slip        Slip?

  @@unique([companyId, idempotencyKey])
  @@index([companyId])
  @@index([invoiceId, status])
  @@index([tenantId, status])
  @@map("payment")
}

// =========================================================================
// Slip — payment proof image (uploaded by tenant). Exactly one slip per
// payment. Stored in R2 private bucket; `sha256` is indexed so we can flag
// slip reuse across payments (tenant trying to pay two invoices with the
// same receipt).
// =========================================================================

model Slip {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  paymentId   String   @unique @map("payment_id") @db.Uuid
  r2ObjectKey String   @map("r2_object_key") @db.VarChar(512)
  mimeType    String   @map("mime_type") @db.VarChar(64)
  sizeBytes   Int      @map("size_bytes")
  // Hex-encoded SHA-256 of the raw bytes — 64 chars. Used for dedupe + fraud check.
  sha256      String   @db.Char(64)
  uploadedAt  DateTime @default(now()) @map("uploaded_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  payment Payment @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([sha256])
  @@map("slip")
}

// =========================================================================
// CompanyLineChannel — per-tenant LINE Official Account configuration.
// One row per company in MVP (`@@unique` on companyId via `@unique` on FK).
//
// Webhook routing:
//   POST /webhooks/line/:channelId  →  lookup CompanyLineChannel by `channelId`
//   →  resolve `companyId` →  withTenant({ companyId, bypassRls: true }, …)
//   The webhook is a PUBLIC route (no JWT — LINE servers call it), so we
//   bootstrap RLS context from the channel-id lookup itself. The lookup
//   itself runs with `bypassRls: true` because there's no tenant context yet.
//
// Secret storage:
//   `channelSecret` + `channelAccessToken` are encrypted at rest via
//   pgcrypto (PiiCryptoService) — same pattern as `tenant.nationalId` /
//   `tenant.phone`. PGP framing inflates a 32-char plaintext to ~300 base64
//   chars and a 200-char access-token plaintext to ~600 chars, so we size
//   `channelSecret VarChar(512)` and `channelAccessToken VarChar(2048)` to
//   absorb both legacy long-lived tokens (≈170 chars) AND v2.1 stateless
//   JWT tokens (which can exceed 300 chars).
//
// `channelId` is GLOBALLY unique (LINE assigns it; one merchant owns it).
// We rely on the global unique index to map an inbound webhook URL to the
// correct company without needing the request to carry a tenant hint.
// =========================================================================

model CompanyLineChannel {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId          String   @unique @map("company_id") @db.Uuid
  /** LINE-assigned channel ID (numeric, ≤32 digits in practice). Unique globally. */
  channelId          String   @unique @map("channel_id") @db.VarChar(32)
  /** Encrypted at rest (pgcrypto). Used for `X-Line-Signature` HMAC verify. */
  channelSecret      String   @map("channel_secret") @db.VarChar(512)
  /** Encrypted at rest (pgcrypto). Used for Messaging API push/reply. */
  channelAccessToken String   @map("channel_access_token") @db.VarChar(2048)
  /** Optional `@xxx` LINE OA basic ID (for deep links / display). */
  basicId            String?  @map("basic_id") @db.VarChar(64)
  /** Optional human-readable label for admin UI. */
  displayName        String?  @map("display_name") @db.VarChar(128)
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@map("company_line_channel")
}

// =========================================================================
// WebhookEvent — durable record of every LINE webhook event we accept.
//
// Two jobs:
//
//   1. **Idempotency / dedup** — LINE retries a webhook on any non-2xx, on
//      timeout, or on its own internal hiccup. The `(companyId, eventId)`
//      unique index lets the controller use `INSERT … ON CONFLICT DO NOTHING`
//      and treat the rowCount as the dedup signal: 0 inserted = replay,
//      ack 200 immediately, no further work.
//
//   2. **Audit + replay buffer** — `payload` keeps the raw event so we can
//      diagnose worker failures or backfill processing if the dispatch logic
//      changes. Worker writes back `status` + `processedAt` + (on failure)
//      `processingError` + `retryCount`.
//
// PK shape: surrogate `id` for FK ergonomics; the dedup contract lives on
// the `(companyId, eventId)` UNIQUE index — `eventId` is LINE-assigned (UUID
// shape) and globally unique in practice, but we scope dedup to companyId
// to keep the index aligned with RLS and avoid a global hot-spot.
//
// `payload Json @db.JsonB` — JSONB for index-friendly partial reads later
// (e.g. filtering by event.type without rehydrating the whole row).
// =========================================================================

enum WebhookEventStatus {
  pending
  processing
  processed
  failed

  @@map("webhook_event_status")
}

model WebhookEvent {
  id              String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId       String             @map("company_id") @db.Uuid
  /** LINE-assigned event id. Globally unique in practice; we still scope dedup to companyId. */
  eventId         String             @map("event_id") @db.VarChar(64)
  /** LINE event type — message / follow / unfollow / postback / join / leave / memberJoined / etc. */
  eventType       String             @map("event_type") @db.VarChar(32)
  /** LINE channel the event arrived on. NOT a FK — channel rows can be re-issued; we keep the raw id. */
  channelId       String             @map("channel_id") @db.VarChar(32)
  /** LINE userId from `event.source.userId`. NULL for events without a user source (group events with no userId, etc.). */
  lineUserId      String?            @map("line_user_id") @db.VarChar(64)
  /** Raw LINE event payload. Keep as JSONB for partial-index potential + replay-friendly diagnostics. */
  payload         Json               @db.JsonB
  /** When LINE timestamps the event (epoch-ms in payload, parsed to timestamptz). */
  eventTimestamp  DateTime           @map("event_timestamp") @db.Timestamptz(6)
  /** When our webhook received the request. */
  receivedAt      DateTime           @default(now()) @map("received_at") @db.Timestamptz(6)
  /** Worker processing state. `pending` = enqueued, awaiting worker pickup. */
  status          WebhookEventStatus @default(pending)
  /** When worker finished (any terminal state — `processed` or `failed`). */
  processedAt     DateTime?          @map("processed_at") @db.Timestamptz(6)
  /** Truncated worker error for forensics. Capped at 1KB to avoid log-blob blowups. */
  processingError String?            @map("processing_error") @db.VarChar(1024)
  /** Worker retry attempt count — incremented per failed BullMQ attempt. */
  retryCount      Int                @default(0) @map("retry_count") @db.SmallInt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  // Dedup contract — controller's INSERT relies on this UNIQUE for ON CONFLICT.
  @@unique([companyId, eventId], name: "webhook_event_company_event_unique")
  // Worker hot path: "give me the next pending event for this tenant, oldest first".
  @@index([companyId, status, receivedAt])
  // Diagnostics path: "show me everything that came in on this LINE channel".
  @@index([channelId])
  @@map("webhook_event")
}

// =========================================================================
// TenantInvite — short-lived single-use code that binds a LINE user to an
// existing Tenant row.
//
// Flow (Task #41):
//   1. Admin creates a Tenant (no lineUserId), then POSTs a generate-invite
//      request. Service returns the plaintext code ONCE; only `codeHash` is
//      stored. Admin shares the code with the human (paper hand-off, SMS,
//      etc.) — out-of-band, never via LINE.
//   2. Tenant opens the LIFF app, types the code. LIFF posts to `/peek` to
//      preview redacted tenant info ("ห้อง 305 — น.ส. ก****"), then `/redeem`
//      with their LINE idToken.
//   3. Server verifies idToken → derives lineUserId → atomically CAS
//      (status='pending' → 'redeemed') AND writes lineUserId to Tenant. Both
//      writes share one transaction; partial failure is impossible.
//
// Token model (8-char base32 displayed as `K7M3-XQ2P`, ~40 bits entropy):
//   - Plaintext NEVER persists. We store only the SHA-256 hex digest.
//   - `codePrefix` (first 4 chars of plaintext) is kept for admin "reissue
//      the one starting with K7M3..." UX without breaking secrecy of the
//      remaining 4 chars.
//   - 7-day TTL — long enough for postal hand-off, short enough that a lost
//     code can't be hoarded for months.
//
// Conflict policy (locked in Task #41 design Q3):
//   If the inbound `lineUserId` is already bound to a *different* Tenant in
//   the same company, redeem rejects with `BIND_CONFLICT`. Audit trail keeps
//   the attempt; admin must manually unbind the colliding tenant before the
//   invite can succeed. We do NOT auto-rebind — silent rebind would corrupt
//   the Contract → Invoice → Payment chain that hangs off the older Tenant.
//
// RLS:
//   Admin endpoints run inside `withTenant({companyId})` so RLS scopes the
//   row by `company_id`. Public peek/redeem endpoints have no tenant context
//   yet — they look up the invite by `code_prefix` under `bypassRls: true`
//   (read-only narrow scope), then SWITCH into `withTenant({companyId})`
//   for the actual mutate (CAS + Tenant.lineUserId update + AuditLog).
// =========================================================================

model TenantInvite {
  id                   String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId            String             @map("company_id") @db.Uuid
  tenantId             String             @map("tenant_id") @db.Uuid
  // SHA-256 hex digest of the plaintext code (lowercase). 64 chars exactly.
  codeHash             String             @map("code_hash") @db.Char(64)
  // First 4 chars of the plaintext code. Used for admin lookup ergonomics
  // (the code shown is `K7M3-XQ2P`; admin can search by `K7M3` to find the
  // row when a tenant calls in saying "the code you gave me starts with…").
  // Storing this is safe: 4 base32 chars = 20 bits — brute-forcing the
  // remaining 4 chars (~20 bits) still requires guessing the hash, and the
  // single-use CAS prevents online enumeration.
  codePrefix           String             @map("code_prefix") @db.Char(4)
  status               TenantInviteStatus @default(pending)
  expiresAt            DateTime           @map("expires_at") @db.Timestamptz(6)
  // Set on terminal transition into `redeemed` (atomic with status flip).
  // For `expired` / `revoked` we leave NULL — those have their own audit row.
  redeemedAt           DateTime?          @map("redeemed_at") @db.Timestamptz(6)
  // The LINE userId that consumed the code. Kept on the invite row for
  // forensics + idempotent replay (if the redeem POST is retried, we can
  // detect "already redeemed by THIS line user → return success" vs
  // "already redeemed by SOMEONE ELSE → 409 conflict").
  redeemedByLineUserId String?            @map("redeemed_by_line_user_id") @db.VarChar(64)
  createdAt            DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  // Admin user who issued the invite. Restrict (not Cascade): keeping the
  // audit trail intact matters more than easy user deletion. If we ever
  // soft-delete users, this still works.
  createdByUserId      String             @map("created_by_user_id") @db.Uuid

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy User  @relation("TenantInviteIssuer", fields: [createdByUserId], references: [id], onDelete: Restrict)

  // Admin list path: "show me all pending invites for this company, newest first".
  @@index([companyId, status, createdAt(sort: Desc)])
  // Admin per-tenant path: "what invites exist for tenant X?"
  @@index([tenantId])
  // Public lookup path: peek/redeem hits this index by codePrefix to narrow
  // the candidate set before constant-time hash compare across the matches.
  @@index([codePrefix, status])
  @@map("tenant_invite")
}

// =========================================================================
// MaintenanceRequest (Sprint B / Task #87)
// =========================================================================
// Tenant-reported repair tickets. Created via LIFF, triaged + resolved by
// staff/manager from admin web. Photos live in R2 (private bucket) — the
// row holds object KEYS only; signed URLs are minted per-request with TTL
// ≤ 5 min (CLAUDE.md §3.9, mirrored from `slip` and `reading.photoKey`).
//
// Status state machine (enforced by MaintenanceService):
//   open → in_progress → resolved → closed
//                ↓
//            cancelled (terminal from any non-resolved state)
//
// `assignedToUserId` is INDEPENDENT of status — a ticket can be `open`
// with no assignee yet, or `in_progress` with a known assignee. The
// service does NOT auto-assign on status flip; admin sets it explicitly
// via the same PATCH endpoint.
//
// `photoR2Keys String[]` — Postgres native array, capped at 10 entries by
// the Zod input schema (LINE rich messages cap at 10 anyway). No separate
// child table for photos: query patterns are always "fetch the ticket,
// show all photos" — never "find tickets where photo X belongs to". An
// array column avoids a JOIN on every read.
//
// Indexes:
//   - (companyId, status) — admin list filtered by status (most common)
//   - (companyId, createdAt DESC) — admin "newest tickets" view
//   - (tenantId, createdAt DESC) — LIFF "my tickets" view
//   - (assignedToUserId) — staff "what's on my plate" (Phase 2 dashboard)
//   - (unitId) — historical view per unit (rare; defensive)
//
// FK delete strategy:
//   - company: Restrict (audit history matters more than easy delete)
//   - unit: Restrict (same — keep history if unit is removed/repurposed)
//   - tenant: Restrict (PII tenant deletes go through soft-delete anyway)
//   - assignedToUser: SetNull (admin user might be removed; ticket survives
//     with "unassigned" assignee, audit log preserves the original)
//
// No `closedAt` column in MVP — `closed` is a terminal state and we read
// `updatedAt` for "when was this closed" if ever needed. Phase 2 may add
// it explicitly if the dashboard needs to display close-out times.
// =========================================================================

model MaintenanceRequest {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  companyId          String              @map("company_id") @db.Uuid
  unitId             String              @map("unit_id") @db.Uuid
  tenantId           String              @map("tenant_id") @db.Uuid
  category           MaintenanceCategory
  title              String              @db.VarChar(128)
  description        String              @db.VarChar(2048)
  priority           MaintenancePriority @default(normal)
  status             MaintenanceStatus   @default(open)
  // R2 object keys — signed URLs minted by API on demand (≤ 5 min TTL).
  // Postgres native array; max 10 entries enforced at the Zod boundary.
  photoR2Keys        String[]            @map("photo_r2_keys") @db.VarChar(512)
  assignedToUserId   String?             @map("assigned_to_user_id") @db.Uuid
  // Public-facing note from staff (shown to tenant on status update).
  // Required by service when status transitions to `resolved` or `cancelled`.
  resolutionNote     String?             @map("resolution_note") @db.VarChar(2048)
  // Set on terminal transition into `resolved`. NULL otherwise (including
  // `cancelled` — that has its own audit row + separate notification).
  resolvedAt         DateTime?           @map("resolved_at") @db.Timestamptz(6)
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  company        Company @relation(fields: [companyId], references: [id], onDelete: Restrict)
  unit           Unit    @relation(fields: [unitId], references: [id], onDelete: Restrict)
  tenant         Tenant  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  assignedToUser User?   @relation("MaintenanceAssignee", fields: [assignedToUserId], references: [id], onDelete: SetNull)

  @@index([companyId, status])
  @@index([companyId, createdAt(sort: Desc)])
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([assignedToUserId])
  @@index([unitId])
  @@map("maintenance_request")
}
