# ============================================================
# Dorm SaaS — Environment Template
# Copy to .env (root) for shared vars, or to each app's own .env
# NEVER commit real secrets. Real .env stays out of git.
# ============================================================

# ---- App URLs ----
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000
LIFF_URL=http://localhost:5173

# ---- PostgreSQL (Neon in prod, local Postgres in dev — see compose.yml) ----
# DATABASE_URL is used by the app at runtime (RLS-wrapped transactions).
# DIRECT_URL bypasses poolers and is used by `prisma migrate`.
DATABASE_URL=postgresql://dorm:dorm_dev_password@localhost:5432/dorm_dev?schema=public
DIRECT_URL=postgresql://dorm:dorm_dev_password@localhost:5432/dorm_dev?schema=public

# ---- Redis (Upstash in prod, local redis in dev) ----
REDIS_URL=redis://localhost:6379

# ---- Auth (Admin) ----
JWT_SECRET=change-me-to-a-long-random-string-min-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# ---- LINE (per-tenant in DB; these are fallback defaults for dev) ----
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=
LINE_CHANNEL_ACCESS_TOKEN=
LINE_LOGIN_CHANNEL_ID=
LIFF_ID=

# ---- Cloudflare R2 ----
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=dorm-saas-dev
R2_PUBLIC_URL=
R2_SIGNED_URL_TTL=300

# ---- PromptPay ----
# Owner's PromptPay ID (national ID / phone / e-wallet).
# In production this is per-company in DB, not env.
PROMPTPAY_ID=

# ---- Slip Verification (Phase 1; leave blank in MVP) ----
SLIP_VERIFIER=manual
EASYSLIP_API_KEY=

# ---- Observability ----
SENTRY_DSN=
POSTHOG_KEY=
LOG_LEVEL=debug

# ---- Feature flags ----
FEATURE_AUTO_SLIP_VERIFY=false
FEATURE_AI_OCR=false
