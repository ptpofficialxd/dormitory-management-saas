# ============================================================
# Dorm SaaS — Test Environment Template
# Copy to .env.test (root) before running `bun run test` in packages/db.
#
# Points at a SEPARATE database (dorm_test) so unit/integration tests can
# truncate tables without touching dev data.
# ============================================================

NODE_ENV=test
DATABASE_URL=postgresql://dorm:dorm_dev_password@localhost:5432/dorm_test?schema=public
DIRECT_URL=postgresql://dorm:dorm_dev_password@localhost:5432/dorm_test?schema=public
REDIS_URL=redis://localhost:6379/1
JWT_SECRET=test-only-jwt-secret-do-not-use-in-prod-min-32-chars
LOG_LEVEL=warn
PRISMA_DEBUG=0
